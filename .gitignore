# Azoth — Apophenia Machine
# Git ignore

# Raw PDFs and large binaries — live in nigredo/ only
nigredo/**/*.pdf
nigredo/**/*.tar.gz

# Runtime outputs generated by normal pipeline runs
albedo/
citrinitas/
rubedo/
athanasor/vigil/reports/
athanasor/lapis/memory.json
athanasor/lapis/memory.jsonl
athanasor/lapis/knowledge_graph.json
athanasor/lapis/knowledge_graph.jsonl
athanasor/embeddings.json
athanasor/embeddings.npy
athanasor/embeddings.store

# Generated YAML — tracked, but registry.jsonl is the canonical index
# (individual library entries are tracked for git history)

# System files
.DS_Store
__pycache__/
*.pyc

# Secrets
.env
*.key
